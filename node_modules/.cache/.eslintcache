ome.module.scss\";\r\n\r\nconst cx = classNames.bind(styles);\r\n\r\nfunction SearchHome() {\r\n  return (\r\n    <div className={cx(\"headerHome__search--wrapper\")}>\r\n      <div className={cx(\"headerHome__search--container\")}>\r\n        <i className={cx(\"headerHome__search--icon\")}></i>\r\n        <input\r\n          type=\"text\"\r\n          className={cx(\"fa\", \"fa-bed\", \"headerHome__search--input\")}\r\n          placeholder=\"Where are you going ?\"\r\n        ></input>\r\n      </div>\r\n\r\n      <div className={cx(\"headerHome__search--container\")}>\r\n        <i className={cx(\"headerHome__search--icon\")}></i>\r\n        <input\r\n          type=\"text\"\r\n          className={cx(\"fa\", \"fa-bed\", \"headerHome__search--input\")}\r\n          placeholder=\"Where are you going ?\"\r\n        ></input>\r\n      </div>\r\n      <button className={cx(\"headerHome__search--button\")}>Search</button>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default SearchHome;\r\n","C:\\Users\\lamgi\\OneDrive\\Tài liệu\\asm-react\\asm1-react\\src\\pages\\home\\HomeHeader\\NavBarItem.js",["99"],[],"import React, { useState } from \"react\";\r\nimport classNames from \"classnames/bind\";\r\nimport styles from \"../../../components/scss/home/HomeHeader/NavBarItem.module.scss\";\r\n\r\nconst cx = classNames.bind(styles);\r\n\r\nfunction NavBarItem(props) {\r\n  return (\r\n    <div\r\n      key={props.key}\r\n      className={cx(\"nav__item\", { \"nav__item--active\": props.active })}\r\n      active={props.active}\r\n    >\r\n      <i className={`fa ${props.icon} ${cx(\"nav__icon\")}`}></i>\r\n      {props.type}\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default NavBarItem;\r\n","C:\\Users\\lamgi\\OneDrive\\Tài liệu\\asm-react\\asm1-react\\src\\pages\\home\\HomeHeader\\SearchDate.js",[],[],{"ruleId":"100","severity":1,"message":"101","line":1,"column":17,"nodeType":"102","messageId":"103","endLine":1,"endColumn":25},{"ruleId":"100","severity":1,"message":"104","li